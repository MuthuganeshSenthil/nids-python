# Phase 1 - Packet Capture
# Run with: sudo python3 packet_capture.py

from scapy.all import sniff, IP, TCP, UDP, ICMP
from datetime import datetime

# ─── CONFIGURATION ────────────────────────────────────────────
INTERFACE = "wlan0"   # Change to wlan0 if using WiFi
PACKET_COUNT = 0     # 0 = capture forever (Ctrl+C to stop)
# ──────────────────────────────────────────────────────────────

packet_number = 0   # We'll count packets ourselves

def get_protocol(packet):
    """
    Figure out if a packet is TCP, UDP, or ICMP.
    Returns the protocol name as a string.
    """
    if TCP in packet:
        return "TCP"
    elif UDP in packet:
        return "UDP"
    elif ICMP in packet:
        return "ICMP"
    else:
        return "OTHER"

def process_packet(packet):
    """
    This function is called AUTOMATICALLY by Scapy
    every time a new packet arrives on the network.
    Think of it as an event listener.
    """
    global packet_number

    # Only process packets that have an IP layer
    # (Some traffic like ARP doesn't have IP)
    if IP not in packet:
        return

    packet_number += 1

    # ── Extract the fields we care about ──
    src_ip    = packet[IP].src        # Who sent it
    dst_ip    = packet[IP].dst        # Who it's going to
    protocol  = get_protocol(packet)  # TCP / UDP / ICMP
    timestamp = datetime.now().strftime("%H:%M:%S")

    # ── Get port numbers (only TCP and UDP have ports) ──
    src_port = "-"
    dst_port = "-"
    if TCP in packet:
        src_port = packet[TCP].sport
        dst_port = packet[TCP].dport
    elif UDP in packet:
        src_port = packet[UDP].sport
        dst_port = packet[UDP].dport

    # ── Print a clean one-line summary ──
    print(
        f"[{timestamp}] #{packet_number:04d} | "
        f"{protocol:<5} | "
        f"{src_ip}:{src_port}  →  {dst_ip}:{dst_port}"
    )

# ─── MAIN ─────────────────────────────────────────────────────
print("=" * 65)
print(f"  NIDS - Packet Capture started on interface: {INTERFACE}")
print("  Press Ctrl+C to stop")
print("=" * 65)

try:
    sniff(
        iface=INTERFACE,        # Which network card to listen on
        prn=process_packet,     # Call process_packet() for every packet
        count=PACKET_COUNT,     # How many packets (0 = infinite)
        store=False             # Don't store packets in RAM (saves memory)
    )
except KeyboardInterrupt:
    print(f"\n\nStopped. Total packets captured: {packet_number}")
